<?php
error_reporting(E_ALL ^ E_DEPRECATED);
$file = "geosafe_logs.csv";
$chart_data = [];
$h = @fopen($file, "r");
if ($h) {
    while (($d = fgetcsv($h, 1000, ",")) !== FALSE) {
        if (count($d) >= 3) {
            $chart_data[] = ["loc" => $d[0], "var" => (floatval($d[2]) - floatval($d[1]))];
        }
    }
    fclose($h);
}
