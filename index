    <script>
        const lgaData = {
            "Ikeja": {depth: 45, lith: "Coastal Plain Sands", lat: 6.6, lng: 3.35, rate: 12000, sop: "Sedimentary zone. High Iron risk. Use PVC casing."},
            "Ankpa": {depth: 60, lith: "Benue Trough Sediments", lat: 7.4, lng: 7.6, rate: 15000, sop: "Moderate rock. Standard DTH rig. Clean water expected."},
            "Kano": {depth: 75, lith: "Basement Complex", lat: 12.0, lng: 8.5, rate: 22000, sop: "Hard Crystalline Rock. Air Percussion required. Fluoride alert."},
            "Port Harcourt": {depth: 32, lith: "Deltaic Sands", lat: 4.82, lng: 7.03, rate: 18000, sop: "Coastal sands. Salinity risk. Treat for corrosive pH."},
            "Effurun": {depth: 28, lith: "Deltaic Formation", lat: 5.56, lng: 5.78, rate: 14000, sop: "Loose sands. Light rig. Fast drilling, high recharge potential."}
        };

        let map = L.map('map', { zoomControl: false }).setView([9.08, 8.67], 5);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png').addTo(map);

        function runAnalysis() {
            const val = document.getElementById('lgaSelect').value;
            if(!val) return;
            const data = lgaData[val];
            const boq = data.depth * data.rate;
            
            document.getElementById('resultBox').classList.remove('hidden');
            document.getElementById('resName').innerText = val + " Intelligence";
            document.getElementById('resDepth').innerText = data.depth + "m";
            document.getElementById('resBOQ').innerText = "₦" + boq.toLocaleString();
            document.getElementById('resSOP').innerText = data.lith + ". " + data.sop;

            map.flyTo([data.lat, data.lng], 12);
            L.marker([data.lat, data.lng]).addTo(map).bindPopup(val).openPopup();
        }

        function shareWhatsApp() {
            const text = encodeURIComponent(`*GEOSAFE BOREHOLE QUOTE*\nLocation: ${document.getElementById('resName').innerText}\nEst. Depth: ${document.getElementById('resDepth').innerText}\nTotal BOQ: ${document.getElementById('resBOQ').innerText}\nSOP: ${document.getElementById('resSOP').innerText}`);
            window.open(`https://wa.me/?text=${text}`);
        }

        function exportPDF() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            doc.setFontSize(20); doc.text("GEOSAFE FIELD AUDIT", 10, 20);
            doc.setFontSize(12); doc.text(document.getElementById('resultBox').innerText, 10, 40);
            doc.save("GeoSafe_Report.pdf");
        }

        function showWHO() {
            alert("WHO Drinking Water Standards:\n- Iron: < 0.3 mg/L\n- Fluoride: < 1.5 mg/L\n- pH: 6.5 - 8.5\n- Lead: 0.01 mg/L");
        }

        const rawData = <?php echo json_encode($chart_data); ?>;
        new Chart(document.getElementById('varianceChart'), {
            type: 'line',
            data: {
                labels: rawData.map(i => i.loc),
                datasets: [{
                    label: 'Variance',
                    data: rawData.map(i => i.var),
                    borderColor: '#10b981',
                    tension: 0.4,
                    fill: false
                }]
            },
            options: { scales: { y: { display: false }, x: { ticks: { color: '#4ade80', font: { size: 8 } } } }, plugins: { legend: { display: false } } }
        });
    </script>
